{
  "expo": {
    "name": "Vai Pro Lixo",
    "slug": "vai-pro-lixo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vaiprolixo",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vaiprolixo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F0DC7A"
      },
      "package": "com.vaiprolixo.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"]
  }
}
